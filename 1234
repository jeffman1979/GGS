Maid:Give(RunService.Heartbeat:Connect(function()
    if not isCurrent() then return end
    local now = tick()
    local char = myChar(); if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end

    lockTarget = nearest(math.max(S.kaRange, S.slamRange))

    if S.killAura and now - lastKill >= math.max(S.kaCD, 0.1) then
        local t = nearest(S.kaRange)
        if t then lastKill = now; task.spawn(killAuraHit, t) end
    end
    if S.autoSlam and now - lastSlam >= S.slamCD then
        if not char:HasTag("slamming") and not char:HasTag("slammed") then
            local t = nearest(math.min(S.slamRange, 10))
            if t and not t:HasTag("slammed") then lastSlam = now; task.spawn(slam, t) end
        end
    end
    if S.autoBlock then
        if now >= blockSuppressUntil and now - lastIncoming <= 0.6 then block() else unblock() end
    elseif isBlocking then unblock() end
end))

