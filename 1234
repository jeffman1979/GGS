pcall(function()
    if not (getgc and hookfunction and newcclosure) then return end
    
    local lp = game:GetService("Players").LocalPlayer
    local noop = function() end
    
    local function findClient()
        for _, v in ipairs(getgc(false)) do
            if typeof(v) == "table" then
                local anti = rawget(v, "Anti")
                local disc = rawget(v, "Disconnect")
                local fns = rawget(v, "Functions")
                if anti and typeof(disc) == "function" and typeof(fns) == "table" and rawget(fns, "Kill") then
                    return v, anti, fns
                end
            end
        end
    end

    local client, anti, fns = findClient()
    if not client then 

        task.delay(1.5, function()
            client, anti, fns = findClient()
            if client then neuter(client, anti, fns) end
        end)
        return 
    end

    local function neuter(c, a, f)
        pcall(function()
            if a and a.Detected then hookfunction(a.Detected, noop) end
            for _, name in {"Kill", "KillClient", "CustomKick", "Crash", "HardCrash", "RAMCrash", "GPUCrash"} do
                local fn = rawget(f, name)
                if fn then 
                    hookfunction(fn, noop)
                    f[name] = noop
                end
            end
            if rawget(c, "Disconnect") then
                hookfunction(c.Disconnect, noop)
                c.Disconnect = noop
            end
        end)
    end

    neuter(client, anti, fns)

    pcall(function()
        local oldKick = hookfunction(lp.Kick, newcclosure(function(self, ...)
            if self == lp then return end
            return oldKick(self, ...)
        end))
    end)
end)

